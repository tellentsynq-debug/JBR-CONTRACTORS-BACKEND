# ⚡ SUPABASE Configuration (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-publishable-key...
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# 🌐 Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:3000

# 🏢 Company Configuration
COMPANY_EMAIL_DOMAIN=@jbrstaffingsolutions.com

# 📧 Gmail Configuration (Optional - for email OTP)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password

# 🔐 JWT Configuration (for token details endpoint)
JWT_SECRET=your-secret-key-change-this-in-production

# 👤 Super Admin Configuration
SUPER_ADMIN_MOBILE=+919876543210

# 📱 SMS Service Configuration (Optional - for Twilio)
# TWILIO_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE=+1234567890
